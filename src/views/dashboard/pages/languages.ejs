<div class="col-12">
    <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fi fi-rr-check me-2"></i>
            <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <% } %>
            <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fi fi-rr-exclamation me-2"></i>
                    <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>

                    <div class="card">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <h6 class="card-title mb-0">
                                <i class="fi fi-rr-globe me-2"></i> Language Management
                            </h6>
                            <a href="/languages/add" class="btn btn-primary btn-sm waves-effect waves-light">
                                <i class="fi fi-rr-plus me-1"></i> Add New Language
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-striped mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="ps-3" style="width: 50px;">#</th>
                                            <th>Code</th>
                                            <th>Title</th>
                                            <th>Flag</th>
                                            <th>Default</th>
                                            <th>Strings</th>
                                            <th>Updated</th>
                                            <th class="text-end pe-3" style="width: 180px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (languages && languages.length> 0) { %>
                                            <% for (var i=0; i < languages.length; i++) { %>
                                                <tr>
                                                    <td class="ps-3">
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-primary-subtle text-primary fw-semibold">
                                                            <%= languages[i].code %>
                                                        </span>
                                                    </td>
                                                    <td class="fw-semibold">
                                                        <%= languages[i].title %>
                                                    </td>
                                                    <td>
                                                        <% if (languages[i].flag) { %>
                                                            <span style="font-size: 1.25rem;">
                                                                <%= languages[i].flag %>
                                                            </span>
                                                            <% } else { %>
                                                                <span class="text-muted">&mdash;</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (languages[i].isDefault) { %>
                                                            <span class="badge bg-success-subtle text-success">
                                                                <i class="fi fi-rr-check me-1"></i> Default
                                                            </span>
                                                            <% } else { %>
                                                                <span class="text-muted">&mdash;</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-info-subtle text-info">
                                                            <%= languages[i].flatStringCount %> keys
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <small class="text-muted">
                                                            <%= new
                                                                Date(languages[i].updatedAt).toLocaleDateString('tr-TR')
                                                                %>
                                                        </small>
                                                    </td>
                                                    <td class="text-end pe-3">
                                                        <div class="d-flex gap-1 justify-content-end">
                                                            <a href="/languages/edit/<%= languages[i]._id %>"
                                                                class="btn btn-sm btn-soft-primary waves-effect waves-light"
                                                                title="Edit">
                                                                <i class="fi fi-rr-pencil"></i>
                                                            </a>
                                                            <% if (!languages[i].isDefault) { %>
                                                                <form action="/languages/delete/<%= languages[i]._id %>"
                                                                    method="POST" class="d-inline"
                                                                    onsubmit="return confirm('Are you sure you want to delete this language?')">
                                                                    <button type="submit"
                                                                        class="btn btn-sm btn-soft-danger waves-effect waves-light"
                                                                        title="Delete">
                                                                        <i class="fi fi-rr-trash"></i>
                                                                    </button>
                                                                </form>
                                                                <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% } %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="8" class="text-center py-5">
                                                                <div
                                                                    class="avatar avatar-xl bg-light rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center">
                                                                    <i class="fi fi-rr-globe fs-1 text-muted"></i>
                                                                </div>
                                                                <h6 class="text-muted mb-2">No languages found</h6>
                                                                <p class="text-muted mb-3">Start by adding your first
                                                                    language.</p>
                                                                <a href="/languages/add"
                                                                    class="btn btn-primary btn-sm waves-effect waves-light">
                                                                    <i class="fi fi-rr-plus me-1"></i> Add Language
                                                                </a>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <% if (languages && languages.length> 0) { %>
                            <div class="card-footer bg-light">
                                <small class="text-muted">
                                    Total: <strong>
                                        <%= languages.length %>
                                    </strong> language(s)
                                </small>
                            </div>
                            <% } %>
                    </div>
</div>