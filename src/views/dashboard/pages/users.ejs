<div class="col-lg-12">
    <div class="card overflow-hidden">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h6 class="card-title mb-0">
                <i class="fi fi-rr-users me-2"></i> Users Management
            </h6>
            <span class="badge bg-primary-subtle text-primary">
                Total: <%= users.length %> users
            </span>
        </div>
        <div class="card-body p-0 pb-2">
            <table id="dt_users" class="table display">
                <thead class="table-light">
                    <tr>
                        <th class="minw-200px">User</th>
                        <th class="minw-200px">Email</th>
                        <th class="minw-150px">Role</th>
                        <th class="minw-100px">Status</th>
                        <th class="minw-150px">Joined Date</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(function(u) { %>
                        <% const userRole=u.getRole ? u.getRole() : 'User' ; const userStatusClass=u.getStatusClass ?
                            u.getStatusClass() : 'secondary' ; const userStatus=u.status ?
                            u.status.charAt(0).toUpperCase() + u.status.slice(1) : 'Offline' ; const
                            joinedDate=u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-US', { year: 'numeric'
                            , month: 'short' , day: 'numeric' }) : 'N/A' ; // Role badge color let
                            roleBadgeClass='secondary' ; if (userRole==='Root' ) roleBadgeClass='danger' ; else if
                            (userRole==='Admin' ) roleBadgeClass='primary' ; else if (userRole==='Mod' )
                            roleBadgeClass='info' ; else if (userRole==='Support' ) roleBadgeClass='warning' ; else if
                            (userRole==='Tester' ) roleBadgeClass='dark' ; else if (userRole==='Banned' )
                            roleBadgeClass='danger' ; else if (userRole==='Suspend' ) roleBadgeClass='secondary' ; %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center mw-175px">
                                        <div class="avatar avatar-xxs rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                            style="width:32px;height:32px;font-size:0.75rem;font-weight:700;min-width:32px;">
                                            <%= u.username ? u.username.charAt(0).toUpperCase() : '?' %>
                                        </div>
                                        <div class="ms-2 me-auto fw-semibold">
                                            <%= u.username %>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-body">
                                        <%= u.email %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= roleBadgeClass %>-subtle text-<%= roleBadgeClass %>">
                                        <%= userRole %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= userStatusClass %>">
                                        <%= userStatus %>
                                    </span>
                                </td>
                                <td>
                                    <%= joinedDate %>
                                </td>
                                <td>
                                    <div class="btn-group float-end">
                                        <a href="/profile" class="btn btn-white btn-sm btn-shadow btn-icon waves-effect"
                                            title="View Profile">
                                            <i class="fi fi-rr-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof $.fn.DataTable !== 'undefined') {
            $('#dt_users').DataTable({
                responsive: true,
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50, 100],
                order: [[4, 'desc']],
                language: {
                    search: '',
                    searchPlaceholder: 'Search users...',
                    lengthMenu: 'Show _MENU_ entries',
                    info: 'Showing _START_ to _END_ of _TOTAL_ users',
                    paginate: {
                        first: '<i class="fi fi-rr-angle-double-small-left"></i>',
                        last: '<i class="fi fi-rr-angle-double-small-right"></i>',
                        next: '<i class="fi fi-rr-angle-small-right"></i>',
                        previous: '<i class="fi fi-rr-angle-small-left"></i>'
                    }
                }
            });
        }
    });
</script>