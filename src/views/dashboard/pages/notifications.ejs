<div class="col-12">
    <div class="card card-body overflow-hidden mail-wrapper p-0">
        <div class="sidebar-mobile-overlay"></div>
        <div class="mail-sidebar bg-light">
            <div class="px-3 pt-3 mb-2">
                <button class="btn btn-primary waves-effect waves-light w-100" onclick="window.location.reload()">
                    Refresh
                </button>
            </div>
            <div class="d-grid gap-2 p-2 mail-nav" role="tablist">
                <a href="/notifications"
                    class="mail-nav-item <%= !filters.category || filters.category === 'all' ? 'active' : '' %>">
                    <i class="fi fi-rr-bell me-2"></i> All Notifications
                    <% if (typeof unreadCount !=='undefined' && unreadCount> 0) { %>
                        <span class="badge badge-sm bg-danger-subtle text-danger ms-auto">
                            <%= unreadCount %>
                        </span>
                        <% } %>
                </a>
                <a href="/notifications?category=system"
                    class="mail-nav-item <%= filters.category === 'system' ? 'active' : '' %>">
                    <i class="fi fi-rr-settings me-2"></i> System Messages
                </a>
                <a href="/notifications?category=announcement"
                    class="mail-nav-item <%= filters.category === 'announcement' ? 'active' : '' %>">
                    <i class="fi fi-rr-megaphone me-2"></i> Announcements
                </a>
                <a href="/notifications?category=general"
                    class="mail-nav-item <%= filters.category === 'general' ? 'active' : '' %>">
                    <i class="fi fi-rr-info me-2"></i> General
                </a>
            </div>
        </div>
        <div class="mail-body">
            <div class="mail-header">
                <button class="btn btn-white btn-shadow btn-icon waves-effect mail-sidebar-toggler d-lg-none">
                    <i class="fi fi-rs-list"></i>
                </button>
                <form class="d-flex align-items-center h-100 w-200px w-md-250px position-relative me-auto" action="#">
                    <button type="button" class="btn btn-sm border-0 position-absolute start-0 ms-3 p-0">
                        <i class="fi fi-rr-search"></i>
                    </button>
                    <input type="text" class="form-control ps-5" placeholder="Search">
                </form>
                <div class="d-flex align-items-center gap-3">
                    <% if (pages> 1) { %>
                        <span>
                            <%= currentPage %> - <%= Math.min(currentPage * limit, total) %> of <%= total %>
                        </span>
                        <div class="d-flex gap-2">
                            <% if (currentPage> 1) { %>
                                <a href="?page=<%= currentPage - 1 %>"
                                    class="btn btn-white btn-shadow btn-icon waves-effect">
                                    <i class="fi fi-rr-angle-left text-2xs"></i>
                                </a>
                                <% } else { %>
                                    <button class="btn btn-white btn-shadow btn-icon waves-effect" disabled>
                                        <i class="fi fi-rr-angle-left text-2xs"></i>
                                    </button>
                                    <% } %>

                                        <% if (currentPage < pages) { %>
                                            <a href="?page=<%= currentPage + 1 %>"
                                                class="btn btn-white btn-shadow btn-icon waves-effect">
                                                <i class="fi fi-rr-angle-right text-2xs"></i>
                                            </a>
                                            <% } else { %>
                                                <button class="btn btn-white btn-shadow btn-icon waves-effect" disabled>
                                                    <i class="fi fi-rr-angle-right text-2xs"></i>
                                                </button>
                                                <% } %>
                        </div>
                        <% } %>
                </div>
            </div>
            <div class="tab-content">
                <div class="tab-pane fade show active">
                    <div class="checkable-wrapper">
                        <!-- Toolbar -->
                        <div class="d-flex bg-light px-3 py-2 align-items-center gap-2 border-bottom">
                            <div class="form-check m-0 ms-1">
                                <input class="form-check-input checkable-check-all" type="checkbox">
                            </div>
                            <a href="javascript:void(0);" class="text-body ms-1" onclick="window.location.reload()">
                                <i class="fi fi-rr-rotate-right"></i>
                            </a>
                        </div>

                        <% if (notifications && notifications.length> 0) { %>
                            <ul class="list-unstyled mail-list m-0 gradient-layer" data-simplebar>
                                <% notifications.forEach(function(notification) { %>
                                    <li
                                        class="mail-list-item checkable-item <%= !notification.read ? 'mail-unread' : '' %>">
                                        <div class="form-check my-0 me-2">
                                            <input class="form-check-input checkable-check-input" type="checkbox">
                                        </div>
                                        <a class="mail-item-bookmark <%= notification.type === 'warning' ? 'active' : '' %>"
                                            href="javascript:void(0);">
                                            <% if (notification.type==='success' ) { %>
                                                <i class="fi fi-rr-check text-success me-2 me-sm-3"></i>
                                                <% } else if (notification.type==='error' ) { %>
                                                    <i class="fi fi-rr-cross text-danger me-2 me-sm-3"></i>
                                                    <% } else if (notification.type==='warning' ) { %>
                                                        <i class="fi fi-rr-exclamation text-warning me-2 me-sm-3"></i>
                                                        <% } else { %>
                                                            <i class="fi fi-rr-bell me-2 me-sm-3"></i>
                                                            <% } %>
                                        </a>
                                        <a href="<%= notification.link || '#' %>"
                                            class="mail-item-content ms-2 ms-sm-0 me-2">
                                            <span class="mail-item-username me-2">
                                                <%= notification.type ? notification.type.charAt(0).toUpperCase() +
                                                    notification.type.slice(1) : 'System' %>
                                            </span>
                                            <span class="mail-item-subject">
                                                <%= notification.title %>
                                            </span>
                                            <span class="mail-item-text text-body"> - <%= notification.message %></span>
                                        </a>
                                        <div class="mail-item-meta ms-auto">
                                            <small class="mail-item-time">
                                                <%= new Date(notification.createdAt).toLocaleTimeString([], {
                                                    hour: '2-digit' , minute: '2-digit' }) %>
                                            </small>
                                            <div class="mail-item-actions">
                                                <button
                                                    class="btn btn-white btn-sm text-danger btn-shadow btn-icon waves-effect"
                                                    title="Delete">
                                                    <i class="fi fi-rr-trash"></i>
                                                </button>
                                                <button class="btn btn-white btn-sm btn-shadow btn-icon waves-effect"
                                                    title="Mark as read">
                                                    <i class="fi fi-rr-envelope-open"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </li>
                                    <% }); %>
                            </ul>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <div class="avatar avatar-xl bg-light rounded-circle mb-3 mx-auto">
                                        <i class="fi fi-rr-bell-slash fs-1 text-muted"></i>
                                    </div>
                                    <h5 class="text-muted">No notifications found</h5>
                                </div>
                                <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>