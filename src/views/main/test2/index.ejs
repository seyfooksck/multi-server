<div class="container">
    <div class="hero-clean text-center">
        <div class="hero-badge">Open Source</div>
        <img class="d-block mx-auto mb-4" src="https://nodejs.org/static/images/logo.svg" alt="Node.js" width="100">
        <h1 class="display-5 fw-bold hero-heading">
            <%= t('HERO.TITLE') %>
        </h1>
        <div class="col-lg-6 mx-auto">
            <p class="lead mb-4 hero-desc">
                <%= t('HERO.SUBTITLE') %>
            </p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <button type="button" class="btn btn-clean-primary btn-lg px-4">
                    <%= t('GET.STARTED') %>
                </button>
                <button type="button" class="btn btn-clean-secondary btn-lg px-4">
                    <%= t('LEARN.MORE') %>
                </button>
            </div>
        </div>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="clean-card">
                <div class="clean-card-icon">⚡</div>
                <h3>Performance</h3>
                <p>Optimized for speed and efficiency with minimal overhead</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="clean-card">
                <div class="clean-card-icon">🛡️</div>
                <h3>Security</h3>
                <p>Enterprise-grade security with built-in protections</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="clean-card">
                <div class="clean-card-icon">🌐</div>
                <h3>Internationalization</h3>
                <p>Multi-language support ready from the start</p>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6 offset-md-3">
            <div class="clean-info text-center">
                <strong>Test Key:</strong>
                <%= t('TEST.TEST.TEST.TEST') %>
            </div>
        </div>
    </div>
</div>