<div class="container">
    <div class="hero-vibrant text-center">
        <div class="hero-pill">✨ Welcome</div>
        <img class="d-block mx-auto mb-4 hero-img-vibrant" src="https://nodejs.org/static/images/logo.svg" alt="Node.js"
            width="110">
        <h1 class="display-4 fw-bold hero-gradient-text">
            <%= t('HERO.TITLE') %>
        </h1>
        <div class="col-lg-6 mx-auto">
            <p class="lead mb-4 hero-text-vibrant">
                <%= t('HERO.SUBTITLE') %>
            </p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <button type="button" class="btn btn-gradient btn-lg px-4">
                    <%= t('GET.STARTED') %>
                </button>
                <button type="button" class="btn btn-glass btn-lg px-4">
                    <%= t('LEARN.MORE') %>
                </button>
            </div>
        </div>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="vibrant-card vibrant-card-1">
                <div class="vibrant-card-icon">🚀</div>
                <h3>Blazing Fast</h3>
                <p>Non-blocking I/O for maximum throughput and performance</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="vibrant-card vibrant-card-2">
                <div class="vibrant-card-icon">🔐</div>
                <h3>Rock Solid</h3>
                <p>Security-first approach with best-in-class protections</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="vibrant-card vibrant-card-3">
                <div class="vibrant-card-icon">🌍</div>
                <h3>Global Ready</h3>
                <p>Full i18n support for worldwide audiences</p>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6 offset-md-3">
            <div class="vibrant-info text-center">
                <strong>Test Key:</strong>
                <%= t('TEST.TEST.TEST.TEST') %>
            </div>
        </div>
    </div>
</div>